# ─────────────────────────────────────────────
#  backend/.env.example
#  Copy this to .env for local development.
#  Never commit .env to git.
# ─────────────────────────────────────────────

APP_NAME=Face Attendance API
APP_VERSION=1.0.0
DEBUG=true

# Local SQLite (dev)
DATABASE_URL=file:./attendance.db
DATABASE_AUTH_TOKEN=

# Production Turso (replace with your real values from turso.tech dashboard)
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# JWT — generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Desktop app sync key
DESKTOP_API_KEY=dev-api-key-change-me

# CORS — comma-separated list of allowed frontend origins
# In production: ALLOWED_ORIGINS=["https://your-app.vercel.app"]
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:4173"]
