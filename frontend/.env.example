# ─────────────────────────────────────────────
#  frontend/.env.example
#  Copy this to .env.local for local development.
#  For Vercel, set these in Project → Settings → Environment Variables.
#  Never commit .env.local to git.
# ─────────────────────────────────────────────

# Leave empty in local dev — Vite proxy handles /api → localhost:8000
# In production (Vercel), set this to your Render backend URL:
# VITE_API_URL=https://face-attendance-api.onrender.com
VITE_API_URL=
